<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	android:id="@+id/mainDrawerLayout" android:layout_width="match_parent"
	android:layout_height="match_parent" android:fitsSystemWindows="true">

	<ScrollView android:layout_width="match_parent"
		android:layout_height="match_parent"
		android:background="@color/mlkit_bg_canvas"
		android:fillViewport="true">

		<LinearLayout android:layout_width="match_parent"
			android:layout_height="wrap_content" android:orientation="vertical"
			android:padding="16dp">

			<LinearLayout android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:gravity="center_vertical" android:orientation="horizontal">

				<androidx.appcompat.widget.AppCompatImageButton
					android:id="@+id/leftMenuButton" android:layout_width="40dp"
					android:layout_height="40dp" android:layout_marginEnd="4dp"
					android:background="@android:color/transparent"
					android:contentDescription="@string/left_menu_content_description"
					android:minHeight="0dp" android:minWidth="0dp"
					android:padding="0dp" android:scaleType="center"
					android:src="@drawable/ic_gmail_menu"
					android:tint="@color/mlkit_on_surface_variant" />

				<com.google.android.material.button.MaterialButton
					android:id="@+id/sourceModeButton"
					android:layout_width="wrap_content" android:layout_height="40dp"
					android:text="@string/source_mode_button"
					android:textAllCaps="false"
					android:textColor="@color/mlkit_primary"
					app:backgroundTint="@android:color/transparent"
					app:cornerRadius="20dp" app:icon="@drawable/ic_marker_config"
					app:iconTint="@color/mlkit_primary"
					app:rippleColor="@color/mlkit_primary"
					app:strokeColor="@color/mlkit_outline" app:strokeWidth="1dp" />

				<TextView android:id="@+id/sourceModeLabel"
					android:layout_width="0dp" android:layout_height="wrap_content"
					android:layout_marginStart="10dp" android:layout_weight="1"
					android:text="@string/source_mode_example"
					android:textColor="@color/mlkit_on_surface_variant"
					android:textStyle="bold" />

				<com.google.android.material.button.MaterialButton
					android:id="@+id/sourceModeActionButton"
					android:layout_width="wrap_content" android:layout_height="40dp"
					android:text="@string/source_action_pick"
					android:textAllCaps="false"
					android:textColor="@color/source_mode_action_text_tint"
					app:backgroundTint="@color/source_mode_action_background_tint"
					app:cornerRadius="20dp" />
			</LinearLayout>

			<LinearLayout android:id="@+id/exampleSourceContainer"
				android:layout_width="match_parent"
				android:layout_height="wrap_content" android:layout_marginTop="8dp"
				android:orientation="vertical">

				<Spinner android:id="@+id/sampleAssetSpinner"
					android:layout_width="match_parent"
					android:layout_height="wrap_content" />
			</LinearLayout>

			<LinearLayout android:id="@+id/fileSourceContainer"
				android:layout_width="match_parent"
				android:layout_height="wrap_content" android:layout_marginTop="8dp"
				android:orientation="vertical" android:visibility="gone">

				<TextView android:id="@+id/localFileNameText"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:background="@drawable/preview_box_background"
					android:ellipsize="middle" android:maxLines="1"
					android:padding="10dp" android:text="@string/source_file_none"
					android:textColor="@color/mlkit_on_surface_variant" />
			</LinearLayout>

			<LinearLayout android:id="@+id/urlSourceContainer"
				android:layout_width="match_parent"
				android:layout_height="wrap_content" android:layout_marginTop="8dp"
				android:orientation="horizontal" android:visibility="gone">

				<EditText android:id="@+id/urlInputText"
					android:layout_width="match_parent" android:layout_height="40dp"
					android:background="@drawable/preview_box_background"
					android:hint="@string/source_url_hint"
					android:importantForAutofill="no" android:inputType="textUri"
					android:maxLines="1" android:paddingStart="10dp"
					android:paddingEnd="10dp"
					android:textColor="@color/mlkit_on_background"
					android:textColorHint="@color/mlkit_on_surface_variant" />
			</LinearLayout>

			<TextView android:layout_width="match_parent"
				android:layout_height="wrap_content" android:layout_marginTop="16dp"
				android:text="@string/label_input_html"
				android:textColor="@color/mlkit_on_background"
				android:textStyle="bold" />

			<FrameLayout android:layout_width="match_parent"
				android:layout_height="190dp" android:layout_marginTop="8dp"
				android:background="@drawable/preview_box_background"
				android:padding="12dp">

				<EditText android:id="@+id/inputHtml"
					android:layout_width="match_parent"
					android:layout_height="match_parent"
					android:background="@android:color/transparent"
					android:fadeScrollbars="false" android:gravity="top|start"
					android:inputType="textMultiLine" android:overScrollMode="always"
					android:padding="0dp" android:scrollbarStyle="insideInset"
					android:scrollbars="vertical"
					android:textColor="@color/mlkit_on_background"
					android:textColorHint="@color/mlkit_on_surface_variant"
					android:textSize="16sp" />

				<WebView android:id="@+id/inputRenderedHtml"
					android:layout_width="match_parent"
					android:layout_height="match_parent" android:visibility="gone" />
			</FrameLayout>

			<TextView android:layout_width="match_parent"
				android:layout_height="wrap_content" android:layout_marginTop="16dp"
				android:text="@string/label_output_html"
				android:textColor="@color/mlkit_on_background"
				android:textStyle="bold" />

			<FrameLayout android:layout_width="match_parent"
				android:layout_height="190dp" android:layout_marginTop="8dp"
				android:background="@drawable/preview_box_background"
				android:padding="12dp">

				<TextView android:id="@+id/outputHtml"
					android:layout_width="match_parent"
					android:layout_height="match_parent" android:fadeScrollbars="false"
					android:gravity="top|start" android:overScrollMode="always"
					android:scrollbarStyle="insideInset" android:scrollbars="vertical"
					android:text="@string/sample_output_placeholder"
					android:textColor="@color/mlkit_on_background"
					android:textSize="16sp" />

				<WebView android:id="@+id/outputRenderedHtml"
					android:layout_width="match_parent"
					android:layout_height="match_parent" android:visibility="gone" />
			</FrameLayout>

			<com.google.android.material.switchmaterial.SwitchMaterial
				android:id="@+id/renderModeToggle"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content" android:layout_marginTop="2dp"
				android:checked="false"
				android:text="@string/label_render_html_mode"
				android:textColor="@color/mlkit_on_background"
				app:useMaterialThemeColors="true" />

			<LinearLayout android:layout_width="match_parent"
				android:layout_height="wrap_content" android:layout_marginTop="2dp"
				android:gravity="center_vertical" android:orientation="horizontal">

				<TextView android:id="@+id/advancedParameterLabel"
					android:layout_width="0dp" android:layout_height="wrap_content"
					android:layout_weight="1"
					android:text="@string/advanced_parameter_label"
					android:textColor="@color/mlkit_on_background"
					android:textSize="14sp" />

				<Space android:layout_width="6dp" android:layout_height="1dp" />

				<com.google.android.material.button.MaterialButton
					android:id="@+id/advancedParameterButton"
					android:layout_width="48dp" android:layout_height="48dp"
					android:elevation="0dp" android:insetTop="0dp"
					android:insetBottom="0dp" android:minWidth="48dp"
					android:minHeight="48dp" android:stateListAnimator="@null"
					android:contentDescription="@string/advanced_parameter_icon_content_description"
					app:backgroundTint="@android:color/transparent"
					app:cornerRadius="24dp" app:icon="@drawable/ic_marker_config"
					app:iconPadding="0dp" app:iconSize="24dp"
					app:iconTint="@color/mlkit_primary"
					app:rippleColor="@color/mlkit_primary" app:strokeWidth="0dp" />
			</LinearLayout>

			<LinearLayout android:layout_width="match_parent"
				android:layout_height="wrap_content" android:layout_marginTop="6dp"
				android:gravity="bottom" android:orientation="horizontal">

				<LinearLayout android:layout_width="0dp"
					android:layout_height="wrap_content" android:layout_weight="1"
					android:orientation="vertical">

					<TextView android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:text="@string/label_source_language"
						android:textColor="@color/mlkit_on_surface_variant" />

					<Spinner android:id="@+id/sourceLanguageSpinner"
						android:layout_width="match_parent"
						android:layout_height="wrap_content" />
				</LinearLayout>

				<Space android:layout_width="12dp" android:layout_height="1dp" />

				<LinearLayout android:layout_width="0dp"
					android:layout_height="wrap_content" android:layout_weight="1"
					android:orientation="vertical">

					<TextView android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:text="@string/label_target_language"
						android:textColor="@color/mlkit_on_surface_variant" />

					<Spinner android:id="@+id/targetLanguageSpinner"
						android:layout_width="match_parent"
						android:layout_height="wrap_content" />
				</LinearLayout>

				<Space android:layout_width="10dp" android:layout_height="1dp" />

				<com.google.android.material.button.MaterialButton
					android:id="@+id/downloadModelButton" android:layout_width="48dp"
					android:layout_height="48dp" android:elevation="0dp"
					android:insetTop="0dp" android:insetBottom="0dp"
					android:minWidth="48dp" android:minHeight="48dp"
					android:stateListAnimator="@null"
					android:contentDescription="@string/download_model_icon_content_description"
					app:backgroundTint="@android:color/transparent"
					app:cornerRadius="24dp" app:icon="@drawable/ic_model_download"
					app:iconPadding="0dp" app:iconSize="24dp"
					app:iconTint="@color/mlkit_primary"
					app:rippleColor="@color/mlkit_primary" app:strokeWidth="0dp" />
			</LinearLayout>

			<LinearLayout android:layout_width="match_parent"
				android:layout_height="wrap_content" android:layout_marginTop="8dp"
				android:baselineAligned="false" android:gravity="center_vertical"
				android:orientation="horizontal">

				<com.google.android.material.button.MaterialButton
					android:id="@+id/explainButton" android:layout_width="0dp"
					android:layout_height="52dp" android:layout_weight="1"
					android:insetLeft="0dp" android:insetRight="0dp"
					android:minWidth="0dp" android:elevation="0dp"
					android:stateListAnimator="@null" android:paddingStart="14dp"
					android:paddingEnd="14dp" android:text="@string/action_explain"
					android:textAllCaps="false"
					android:textColor="@android:color/white" android:translationZ="0dp"
					app:backgroundTint="@color/mlkit_primary" app:cornerRadius="14dp"
					app:strokeColor="@color/mlkit_outline" app:strokeWidth="0dp" />

				<Space android:layout_width="10dp" android:layout_height="1dp" />

				<com.google.android.material.button.MaterialButton
					android:id="@+id/translateButton" android:layout_width="0dp"
					android:layout_height="52dp" android:layout_weight="1"
					android:elevation="0dp" android:stateListAnimator="@null"
					android:text="@string/action_translate" android:textAllCaps="false"
					android:textColor="@color/translate_button_text_color"
					android:translationZ="0dp"
					app:backgroundTint="@color/translate_button_background_tint"
					app:cornerRadius="14dp" />
			</LinearLayout>

			<LinearLayout
				android:id="@+id/translationProgressContainer"
				android:layout_width="match_parent"
				android:layout_height="wrap_content" android:layout_marginTop="12dp"
				android:gravity="center_vertical" android:orientation="horizontal"
				android:visibility="gone">

				<com.google.android.material.progressindicator.CircularProgressIndicator
					android:id="@+id/translationProgressBar"
					android:layout_width="20dp" android:layout_height="20dp"
					android:indeterminate="true"
					app:indicatorColor="@color/mlkit_primary" app:indicatorInset="0dp"
					app:indicatorSize="20dp" app:trackColor="@color/mlkit_outline"
					app:trackThickness="2dp" />

				<TextView android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:layout_marginStart="8dp"
					android:text="@string/status_translating"
					android:textColor="@color/mlkit_on_surface_variant" />
			</LinearLayout>

			<TextView android:id="@+id/translationResultText"
				android:layout_width="match_parent"
				android:layout_height="wrap_content" android:layout_marginTop="8dp"
				android:textColor="@color/mlkit_on_surface_variant"
				android:visibility="gone" />
		</LinearLayout>
	</ScrollView>

	<com.google.android.material.navigation.NavigationView
		android:id="@+id/leftNavigationView"
		android:layout_width="wrap_content"
		android:layout_height="match_parent" android:layout_gravity="start"
		android:background="@color/mlkit_bg_canvas"
		android:fitsSystemWindows="true"
		app:headerLayout="@layout/nav_header_main"
		app:itemIconTint="@color/mlkit_on_surface_variant"
		app:itemTextColor="@color/mlkit_on_background"
		app:menu="@menu/main_drawer_menu" />

</androidx.drawerlayout.widget.DrawerLayout>
