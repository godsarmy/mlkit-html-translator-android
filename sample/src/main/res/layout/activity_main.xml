<?xml version="1.0" encoding="utf-8"?>
<ScrollView
	xmlns:android="http://schemas.android.com/apk/res/android"
	android:layout_width="match_parent"
	android:layout_height="match_parent" android:fillViewport="true">

	<LinearLayout android:layout_width="match_parent"
		android:layout_height="wrap_content" android:orientation="vertical"
		android:padding="16dp">

		<TextView android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:text="@string/label_source_language" />

		<Spinner android:id="@+id/sourceLanguageSpinner"
			android:layout_width="match_parent"
			android:layout_height="wrap_content" />

		<TextView android:layout_width="match_parent"
			android:layout_height="wrap_content" android:layout_marginTop="8dp"
			android:text="@string/label_target_language" />

		<Spinner android:id="@+id/targetLanguageSpinner"
			android:layout_width="match_parent"
			android:layout_height="wrap_content" />

		<LinearLayout android:layout_width="match_parent"
			android:layout_height="wrap_content" android:layout_marginTop="12dp"
			android:orientation="horizontal">

			<Button android:id="@+id/downloadModelButton"
				android:layout_width="0dp" android:layout_height="wrap_content"
				android:layout_weight="1"
				android:text="@string/action_download_model" />

			<Button android:id="@+id/deleteModelButton"
				android:layout_width="0dp" android:layout_height="wrap_content"
				android:layout_weight="1" android:text="@string/action_delete_model" />

			<Button android:id="@+id/checkModelButton"
				android:layout_width="0dp" android:layout_height="wrap_content"
				android:layout_weight="1" android:text="@string/action_check_model" />
		</LinearLayout>

		<TextView android:id="@+id/modelStatus"
			android:layout_width="match_parent"
			android:layout_height="wrap_content" android:layout_marginTop="8dp"
			android:text="@string/model_status_placeholder" />

		<TextView android:layout_width="match_parent"
			android:layout_height="wrap_content" android:layout_marginTop="12dp"
			android:text="@string/label_sample_asset" />

		<Spinner android:id="@+id/sampleAssetSpinner"
			android:layout_width="match_parent"
			android:layout_height="wrap_content" />

		<Button android:id="@+id/loadSampleButton"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:text="@string/action_load_sample" />

		<TextView android:layout_width="match_parent"
			android:layout_height="wrap_content" android:layout_marginTop="12dp"
			android:text="@string/label_input_html" />

		<EditText android:id="@+id/inputHtml"
			android:layout_width="match_parent" android:layout_height="160dp"
			android:gravity="top|start" android:inputType="textMultiLine"
			android:minHeight="120dp" />

		<CheckBox android:id="@+id/enableTimingCheckbox"
			android:layout_width="match_parent"
			android:layout_height="wrap_content" android:checked="false"
			android:text="@string/label_enable_timing" />

		<Button android:id="@+id/translateButton"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:text="@string/action_translate" />

		<TextView android:layout_width="match_parent"
			android:layout_height="wrap_content" android:layout_marginTop="12dp"
			android:text="@string/label_error_code" />

		<TextView android:id="@+id/errorCode"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:text="@string/error_none" />

		<TextView android:layout_width="match_parent"
			android:layout_height="wrap_content" android:layout_marginTop="12dp"
			android:text="@string/label_timing_report" />

		<TextView android:id="@+id/timingReport"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:text="@string/timing_disabled_message" />

		<TextView android:layout_width="match_parent"
			android:layout_height="wrap_content" android:layout_marginTop="12dp"
			android:text="@string/label_output_html" />

		<TextView android:id="@+id/outputHtml"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:text="@string/sample_output_placeholder" />
	</LinearLayout>
</ScrollView>
