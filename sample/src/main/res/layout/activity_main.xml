<?xml version="1.0" encoding="utf-8"?>
<ScrollView
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:background="@color/mlkit_bg_canvas" android:fillViewport="true">

	<LinearLayout android:layout_width="match_parent"
		android:layout_height="wrap_content" android:orientation="vertical"
		android:padding="16dp">

		<TextView android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:text="@string/label_sample_asset"
			android:textColor="@color/mlkit_on_surface_variant" />

		<Spinner android:id="@+id/sampleAssetSpinner"
			android:layout_width="match_parent"
			android:layout_height="wrap_content" />

		<TextView android:layout_width="match_parent"
			android:layout_height="wrap_content" android:layout_marginTop="16dp"
			android:text="@string/label_input_html"
			android:textColor="@color/mlkit_on_background"
			android:textStyle="bold" />

		<FrameLayout android:layout_width="match_parent"
			android:layout_height="190dp" android:layout_marginTop="8dp"
			android:background="@drawable/preview_box_background"
			android:padding="12dp">

			<EditText android:id="@+id/inputHtml"
				android:layout_width="match_parent"
				android:layout_height="match_parent"
				android:background="@android:color/transparent"
				android:fadeScrollbars="false" android:gravity="top|start"
				android:inputType="textMultiLine" android:overScrollMode="always"
				android:padding="0dp" android:scrollbarStyle="insideInset"
				android:scrollbars="vertical"
				android:textColor="@color/mlkit_on_background"
				android:textColorHint="@color/mlkit_on_surface_variant" />
		</FrameLayout>

		<TextView android:layout_width="match_parent"
			android:layout_height="wrap_content" android:layout_marginTop="16dp"
			android:text="@string/label_output_html"
			android:textColor="@color/mlkit_on_background"
			android:textStyle="bold" />

		<FrameLayout android:layout_width="match_parent"
			android:layout_height="190dp" android:layout_marginTop="8dp"
			android:background="@drawable/preview_box_background"
			android:padding="12dp">

			<TextView android:id="@+id/outputHtml"
				android:layout_width="match_parent"
				android:layout_height="match_parent" android:fadeScrollbars="false"
				android:gravity="top|start" android:overScrollMode="always"
				android:scrollbarStyle="insideInset" android:scrollbars="vertical"
				android:text="@string/sample_output_placeholder"
				android:textColor="@color/mlkit_on_background" />
		</FrameLayout>

		<LinearLayout android:layout_width="match_parent"
			android:layout_height="wrap_content" android:layout_marginTop="14dp"
			android:orientation="horizontal">

			<LinearLayout android:layout_width="0dp"
				android:layout_height="wrap_content" android:layout_weight="1"
				android:orientation="vertical">

				<TextView android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:text="@string/label_source_language"
					android:textColor="@color/mlkit_on_surface_variant" />

				<Spinner android:id="@+id/sourceLanguageSpinner"
					android:layout_width="match_parent"
					android:layout_height="wrap_content" />
			</LinearLayout>

			<Space android:layout_width="12dp" android:layout_height="1dp" />

			<LinearLayout android:layout_width="0dp"
				android:layout_height="wrap_content" android:layout_weight="1"
				android:orientation="vertical">

				<TextView android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:text="@string/label_target_language"
					android:textColor="@color/mlkit_on_surface_variant" />

				<Spinner android:id="@+id/targetLanguageSpinner"
					android:layout_width="match_parent"
					android:layout_height="wrap_content" />
			</LinearLayout>
		</LinearLayout>

		<com.google.android.material.button.MaterialButton
			android:id="@+id/downloadModelButton"
			android:layout_width="match_parent" android:layout_height="50dp"
			android:layout_marginTop="12dp"
			android:text="@string/action_download_model"
			android:textAllCaps="false"
			android:textColor="@color/mlkit_on_background"
			app:backgroundTint="@color/mlkit_bg_elevated" app:cornerRadius="14dp"
			app:strokeColor="@color/mlkit_outline" app:strokeWidth="1dp" />

		<com.google.android.material.button.MaterialButton
			android:id="@+id/translateButton" android:layout_width="match_parent"
			android:layout_height="52dp" android:layout_marginTop="12dp"
			android:text="@string/action_translate" android:textAllCaps="false"
			android:textColor="@android:color/white"
			app:backgroundTint="@color/mlkit_primary" app:cornerRadius="14dp" />

		<TextView android:layout_width="match_parent"
			android:layout_height="wrap_content" android:layout_marginTop="16dp"
			android:text="@string/label_error_code"
			android:textColor="@color/mlkit_on_surface_variant" />

		<TextView android:id="@+id/errorCode"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:text="@string/error_none"
			android:textColor="@color/mlkit_error" android:textStyle="bold" />

		<TextView android:layout_width="match_parent"
			android:layout_height="wrap_content" android:layout_marginTop="8dp"
			android:text="@string/label_timing_report"
			android:textColor="@color/mlkit_on_surface_variant" />

		<TextView android:id="@+id/timingReport"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginBottom="4dp" android:text=""
			android:textColor="@color/mlkit_on_surface_variant" />
	</LinearLayout>
</ScrollView>
